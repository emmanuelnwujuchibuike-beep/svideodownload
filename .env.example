# ----------------------------------------------------------------------
# SVideoDownload — environment variables
# Copy to `.env.local` for development. Set these in Vercel for production.
# ----------------------------------------------------------------------

# Public site URL (used for SEO, canonical, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server only — NEVER expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Upstash Redis (rate limiting / caching) --------------------------
# Optional locally (falls back to in-memory limiter). Required in production.
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- yt-dlp -----------------------------------------------------------
# Path to the yt-dlp binary. Leave as "yt-dlp" if it's on PATH.
YTDLP_PATH=yt-dlp
# Path to the ffmpeg binary (used to merge video+audio and transcode audio).
# Leave blank to rely on ffmpeg being on PATH.
FFMPEG_PATH=
# Path to aria2c (optional): a multi-connection downloader. Helps direct-CDN
# sources (TikTok/Instagram) but can SLOW DOWN throttled sources like YouTube,
# so it is OFF by default. Set USE_ARIA2C=true to enable it where it helps.
ARIA2C_PATH=
USE_ARIA2C=false
# Parallel fragments for the native (default) downloader. Higher = faster on
# segmented (DASH/HLS) formats, up to the source's throttle limit.
YTDLP_CONCURRENT_FRAGMENTS=8
# Metadata extraction timeout in milliseconds (extraction is quick).
YTDLP_TIMEOUT_MS=25000
# Download IDLE timeout (ms): a download is aborted only after this long with
# NO progress (a hang). Long videos/audio that keep advancing are never cut off.
YTDLP_DOWNLOAD_IDLE_TIMEOUT_MS=180000

# --- Extraction & metadata cache -------------------------------------
# Custom extractors (TikTok, etc.) bypass yt-dlp for speed; yt-dlp is the
# fallback. Extracted metadata is cached in Redis (or memory) by URL.
METADATA_CACHE_TTL_SECONDS=1800
TIKTOK_EXTRACTOR_TIMEOUT_MS=8000
PROXY_DOWNLOAD_TIMEOUT_MS=20000
# Residential/rotating HTTP proxy for custom extractors. TikTok (and some other
# sites) serve a bot/WAF challenge to datacenter IPs, so the fast custom path
# needs a non-flagged egress IP in production. Without this it transparently
# falls back to yt-dlp. e.g. http://user:pass@proxy-host:port
EXTRACTOR_PROXY=

# --- Download cache (speed at scale) ---------------------------------
# Repeat requests for the same url+format are served from disk in ms, and
# concurrent identical requests are coalesced into ONE yt-dlp run.
DOWNLOAD_CACHE_ENABLED=true
DOWNLOAD_CACHE_TTL_MS=600000
DOWNLOAD_CACHE_MAX_BYTES=2000000000
# DOWNLOAD_CACHE_DIR=/var/cache/svideodownload   # defaults to the OS temp dir

# --- Scaling / throughput --------------------------------------------
# Per-instance cap on simultaneous downloads (each spawns yt-dlp + ffmpeg).
# Total capacity ≈ instances × DOWNLOAD_MAX_CONCURRENCY. Tune to your CPU/RAM.
DOWNLOAD_MAX_CONCURRENCY=16
# Max requests allowed to wait for a slot before shedding load with HTTP 503.
DOWNLOAD_MAX_QUEUE=256

# --- Rate limiting ----------------------------------------------------
# Set to false/0/off for UNLIMITED downloads (no per-user throttling).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_METADATA_PER_MIN=60
RATE_LIMIT_DOWNLOAD_PER_MIN=30

# --- Analytics (optional) ---------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_ID=

# --- Monitoring (optional) --------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Monetization (optional) ------------------------------------------
NEXT_PUBLIC_ADSENSE_CLIENT=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
LEMONSQUEEZY_API_KEY=
