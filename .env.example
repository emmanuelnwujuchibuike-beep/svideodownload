# ----------------------------------------------------------------------
# SVideoDownload — environment variables
# Copy to `.env.local` for development. Set these in Vercel for production.
# ----------------------------------------------------------------------

# Public site URL (used for SEO, canonical, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Frontend / Worker split -----------------------------------------
# FRONTEND (Vercel): set DOWNLOAD_WORKER_URL to your worker's URL so heavy
#   routes (/api/metadata, /api/download) proxy there instead of needing
#   yt-dlp/ffmpeg locally (Vercel serverless has neither).
# WORKER (Docker/Fly/Railway): leave DOWNLOAD_WORKER_URL BLANK; it does the work.
# Both must share the SAME WORKER_SECRET so the worker only accepts the frontend.
DOWNLOAD_WORKER_URL=
WORKER_SECRET=

# --- Supabase ---------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server only — NEVER expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Upstash Redis (rate limiting / caching) --------------------------
# Optional locally (falls back to in-memory limiter). Required in production.
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- yt-dlp -----------------------------------------------------------
# Path to the yt-dlp binary. Leave as "yt-dlp" if it's on PATH.
YTDLP_PATH=yt-dlp
# Path to the ffmpeg binary (used to merge video+audio and transcode audio).
# Leave blank to rely on ffmpeg being on PATH.
FFMPEG_PATH=
# Path to aria2c (optional): a multi-connection downloader. Helps direct-CDN
# sources (TikTok/Instagram) but can SLOW DOWN throttled sources like YouTube,
# so it is OFF by default. Set USE_ARIA2C=true to enable it where it helps.
ARIA2C_PATH=
USE_ARIA2C=false
# Parallel fragments for the native (default) downloader. Higher = faster on
# segmented (DASH/HLS) formats, up to the source's throttle limit.
YTDLP_CONCURRENT_FRAGMENTS=8
# Metadata extraction timeout in milliseconds (extraction is quick).
YTDLP_TIMEOUT_MS=25000
# Download IDLE timeout (ms): a download is aborted only after this long with
# NO progress (a hang). Long videos/audio that keep advancing are never cut off.
YTDLP_DOWNLOAD_IDLE_TIMEOUT_MS=180000

# --- Extraction & metadata cache -------------------------------------
# Custom extractors (TikTok, etc.) bypass yt-dlp for speed; yt-dlp is the
# fallback. Extracted metadata is cached in Redis (or memory) by URL.
METADATA_CACHE_TTL_SECONDS=1800
TIKTOK_EXTRACTOR_TIMEOUT_MS=8000
PROXY_DOWNLOAD_TIMEOUT_MS=20000
# --- Residential proxy (smart, fallback-only) ------------------------
# Used ONLY as a fallback when a platform blocks the server's IP (403/429/
# challenge), and ONLY for small extraction requests — never for streaming
# video bytes — so bandwidth/cost stays tiny. Set these on the WORKER.
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_PROTOCOL=http
# Try direct first, only use the proxy after a direct request is blocked:
PROXY_FALLBACK_ONLY=true
# Platforms allowed to use the proxy on a block (comma-separated):
PROXY_PLATFORMS=instagram,facebook,twitter,snapchat,linkedin
# Platforms that ALWAYS stay direct (never proxy):
PROXY_DIRECT_PLATFORMS=tiktok,pinterest,youtube
# Monthly proxy bandwidth budget (GB). Proxy is auto-disabled once exceeded:
PROXY_BANDWIDTH_LIMIT_GB=2
# Optional: $ per GB for cost estimates in the admin widget:
PROXY_COST_PER_GB=0
# Legacy single-URL proxy (still honored if the PROXY_* vars above are unset):
EXTRACTOR_PROXY=

# yt-dlp cookies (Netscape cookies.txt CONTENTS, not a path). Lets the worker
# authenticate sign-in-walled sites (Instagram, Facebook) and private/age-gated
# videos. Export cookies.txt from a logged-in browser session and paste here.
# Set this on the WORKER (where yt-dlp runs), not the Vercel frontend.
YTDLP_COOKIES=

# --- Download cache (speed at scale) ---------------------------------
# Repeat requests for the same url+format are served from disk in ms, and
# concurrent identical requests are coalesced into ONE yt-dlp run.
DOWNLOAD_CACHE_ENABLED=true
DOWNLOAD_CACHE_TTL_MS=600000
DOWNLOAD_CACHE_MAX_BYTES=2000000000
# DOWNLOAD_CACHE_DIR=/var/cache/svideodownload   # defaults to the OS temp dir

# --- Scaling / throughput --------------------------------------------
# Per-instance cap on simultaneous downloads (each spawns yt-dlp + ffmpeg).
# Total capacity ≈ instances × DOWNLOAD_MAX_CONCURRENCY. Tune to your CPU/RAM.
DOWNLOAD_MAX_CONCURRENCY=16
# Max requests allowed to wait for a slot before shedding load with HTTP 503.
DOWNLOAD_MAX_QUEUE=256

# --- Rate limiting ----------------------------------------------------
# Set to false/0/off for UNLIMITED downloads (no per-user throttling).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_METADATA_PER_MIN=60
RATE_LIMIT_DOWNLOAD_PER_MIN=30

# --- Analytics (optional) ---------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_ID=

# --- Monitoring (optional) --------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Monetization (optional) ------------------------------------------
NEXT_PUBLIC_ADSENSE_CLIENT=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
LEMONSQUEEZY_API_KEY=

# --- Cloudflare R2 (main media storage) -------------------------------
# Large media (videos, reels, story media) is stored in R2 (zero egress,
# CDN-served). If UNSET, everything falls back to Supabase Storage, so the
# app keeps working. Create an R2 bucket + an R2 API token (S3 keys) and set:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket — the R2.dev subdomain (Bucket → Settings →
# Public access → Allow, gives https://pub-xxxx.r2.dev) or a custom domain.
R2_PUBLIC_BASE_URL=

# --- Cloudflare Stream (instant adaptive-bitrate video) ---------------
# Optional. When set, video posts can play via Stream (HLS, quality ladder,
# instant start) instead of downloading the whole R2 file. Without it, video
# plays from R2/Supabase as before. Create an API token with Stream:Edit.
CF_STREAM_ACCOUNT_ID=
CF_STREAM_API_TOKEN=
# Public customer code (for building HLS/thumbnail URLs client-side). Find it
# in any Stream embed URL: customer-<CODE>.cloudflarestream.com
NEXT_PUBLIC_CF_STREAM_CUSTOMER_CODE=
